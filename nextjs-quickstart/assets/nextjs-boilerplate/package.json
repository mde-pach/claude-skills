    "@types/react-dom": "^19",
    "@types/pg": "^8.11.10",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
